@model DrozdovLaw.Models.ViewModels.CaseViewModel
@{
    ViewBag.Lang = Model.Language;
    ViewBag.Title = Model.Page != null && !string.IsNullOrEmpty(Model.Page.Status) 
        ? Model.Page.Status 
        : (Model.Section?.Slug ?? Model.Page?.Name ?? "Case");
    ViewBag.PageLayoutClass = "m-light";

    // Стили для зон (сравниваем по имени стиля)
    var headStyles    = new[] { "breadcrumb", "e-dots", "h1", "e-id", "e-details__type", "e-details__loc", "e-details__def" };
    var asideStyles   = new[] { "person", "note-title", "note-text" };
    var bottomStyles  = new[] { "decision-title", "decision-text", "case-link", "docs-title", "doc-item", "tags-title", "tag" };
    var sectionStyles = new[] { "section-title" };

    // Распределение блоков по зонам (учитываем, что b.Style – объект, берём b.Style.Name)
    var headBlocks    = Model.Blocks.Where(b => headStyles.Contains(b.Style.Name)).ToList();
    var bodyBlocks    = Model.Blocks.Where(b => !headStyles.Contains(b.Style.Name)
                                             && !asideStyles.Contains(b.Style.Name)
                                             && !bottomStyles.Contains(b.Style.Name)
                                             && !sectionStyles.Contains(b.Style.Name)).ToList();
    var asideBlocks   = Model.Blocks.Where(b => asideStyles.Contains(b.Style.Name)).ToList();
    var bottomBlocks  = Model.Blocks.Where(b => bottomStyles.Contains(b.Style.Name)).ToList();
    
    var sectionTitle  = Model.Blocks.FirstOrDefault(b => b.Style.Name == "section-title");
}

<section class="container">
    @* Хлебные крошки *@
    @foreach (var b in headBlocks.Where(b => b.Style.Name == "breadcrumb"))
    { 
        @await Html.PartialAsync("_ContentBlock", b) 
    }

    <div class="section-article">
        <div class="section-article__content">
            <div class="section-article__head">
                @foreach (var b in headBlocks.Where(b => b.Style.Name is "e-dots" or "h1" or "e-id"))
                {
                    @await Html.PartialAsync("_ContentBlock", b)
                }

                <a href="#" class="btn-primary u-not-desktop">
                    @(Model.Language == "ru" ? "Получить консультацию" : "Get a consultation")
                </a>

                <div class="e-details">
                    @foreach (var b in headBlocks.Where(b => b.Style.Name is "e-details__type" or "e-details__loc" or "e-details__def"))
                    {
                        @await Html.PartialAsync("_ContentBlock", b)
                    }
                </div>
            </div>

            @foreach (var b in bodyBlocks)
            { 
                @await Html.PartialAsync("_ContentBlock", b) 
            }
        </div>

        <div class="section-article__aside">
            <a href="#" class="btn-primary u-desktop-only">
                @(Model.Language == "ru" ? "Получить консультацию" : "Get a consultation")
            </a>

            @{ var personBlocks = asideBlocks.Where(b => b.Style.Name == "person").ToList(); }
            @if (personBlocks.Any())
            {
                <div class="person-min-wrap u-after-load">
                    @foreach (var b in personBlocks)
                    { 
                        @await Html.PartialAsync("_ContentBlock", b) 
                    }
                </div>
            }

            @{ var noteBlocks = asideBlocks.Where(b => b.Style.Name is "note-title" or "note-text").ToList(); }
            @if (noteBlocks.Any())
            {
                <div class="section-article__notes u-after-load">
                    @{
                        bool hasOpenDiv = false;
                        foreach (var b in noteBlocks)
                        {
                            if (b.Style.Name == "note-title")
                            {
                                if (hasOpenDiv) { @:</div> 
                                }
                                @:<div class="section-article__note">
                                hasOpenDiv = true;
                            }
                            @await Html.PartialAsync("_ContentBlock", b)
                        }
                        if (hasOpenDiv) { @:</div> 
                        }
                    }
                </div>
            }
        </div>
    </div>

    @if (bottomBlocks.Any())
    {
        <div class="section-article__bottom">
            <div class="section-article__content">
                @foreach (var b in bottomBlocks.Where(b => b.Style.Name is "decision-title" or "decision-text" or "case-link"))
                {
                    @await Html.PartialAsync("_ContentBlock", b)
                }

                @{ 
                    var docTitle = bottomBlocks.FirstOrDefault(b => b.Style.Name == "docs-title");
                    var docItems = bottomBlocks.Where(b => b.Style.Name == "doc-item").ToList();
                }
                @if (docItems.Any())
                {
                    if (docTitle != null) { @await Html.PartialAsync("_ContentBlock", docTitle) }
                    <div class="docs-blocks">
                        @foreach (var b in docItems)
                        { 
                            @await Html.PartialAsync("_ContentBlock", b) 
                        }
                    </div>
                }

                @{ 
                    var tagsTitle = bottomBlocks.FirstOrDefault(b => b.Style.Name == "tags-title");
                    var tags = bottomBlocks.Where(b => b.Style.Name == "tag").ToList();
                }
                @if (tags.Any())
                {
                    <div class="tags">
                        @if (tagsTitle != null) { @await Html.PartialAsync("_ContentBlock", tagsTitle) }
                        <ul>
                            @foreach (var b in tags)
                            {
                                <li>@await Html.PartialAsync("_ContentBlock", b)</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    }
</section>

@* Похожие разделы *@
<div class="section-grey">
    <div class="content">
        <section class="container">
            @if (sectionTitle != null)
            { 
                @await Html.PartialAsync("_ContentBlock", sectionTitle) 
            }
        </section>
        <div class="cards m-type-2 m-type-2a">
            @foreach (var sec in Model.SimilarSections)   @* ← переименовано в sec *@
            {
                var page = sec.Pages?.FirstOrDefault(p => p.LanguageCode == Model.Language);
        var pageName = page?.Name ?? sec.Slug;
        var status = page?.Status ?? sec.Slug;
        var summary = page?.Summary ?? "";
        <a href="@Url.Action("Detail", "Case", new { slug = sec.Slug, lang = Model.Language })" class="cards__item">
            <div class="e-status" style="color:@sec.StatusColor">@status</div>
            <h2>@pageName</h2>
            @if (!string.IsNullOrEmpty(sec.FlagImage))
            {
                <div class="e-location">
                    <span class="flag-icon"><img src="~/images/@sec.FlagImage.Replace("images/", "")" alt=""></span>
                    @summary
                </div>
            }

        </a>
            }
            @if (!Model.SimilarSections.Any())
            {
                <p style="color:#999;padding:20px">@(Model.Language == "ru" ? "Других кейсов пока нет." : "No other cases yet.")</p>
            }
        </div>
        <div class="more-link">
            <a href="@Url.Action("List","Case", new { lang = Model.Language })" class="btn-secondary">
                @(Model.Language == "ru" ? "Больше кейсов" : "More cases")
            </a>
        </div>
    </div>
</div>