@model DrozdovLaw.Models.ViewModels.CasesListViewModel
@{
    ViewBag.Lang = Model.Language;
    ViewBag.Title = Model.Language == "ru" ? "Все разделы" : "All sections";
}

<section class="container">
    <div class="breadcrumbs">
        <ul>
            <li><a href="/">@(Model.Language == "ru" ? "Главная" : "Home")</a></li>
            <li><a href="#">@(Model.Language == "ru" ? "Разделы" : "Sections")</a></li>
        </ul>
    </div>
    <h1>@(Model.Language == "ru" ? "Разделы" : "Sections")</h1>
</section>

<div class="cards m-type-2">
    @foreach (var sec in Model.Sections.Where(s => s.IsPublished))
    {
        var page = sec.Pages?.FirstOrDefault(p => p.LanguageCode == Model.Language);
        var pageName = page?.Name ?? sec.Slug;
        var status = page?.Status ?? sec.Slug;
        var summary = page?.Summary ?? "";
        <a href="@Url.Action("Detail", "Case", new { slug = sec.Slug, lang = Model.Language })" class="cards__item">
            <div class="e-status" style="color:@sec.StatusColor">@status</div>
            <h2>@pageName</h2>
            @if (!string.IsNullOrEmpty(sec.FlagImage))
            {
                <div class="e-location">
                    <span class="flag-icon"><img src="~/images/@sec.FlagImage.Replace("images/", "")" alt=""></span>
                    @summary
                </div>
            }

        </a>
    }
    @if (!Model.Sections.Any(s => s.IsPublished))
    {
        <p style="padding:40px;color:#888">
            @(Model.Language == "ru" ? "Разделов пока нет." : "No sections yet.")
        </p>
    }
</div>