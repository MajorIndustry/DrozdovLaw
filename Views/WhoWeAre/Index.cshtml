@model DrozdovLaw.Models.ViewModels.PageViewModel
@{
    ViewBag.Lang = Model.Language;
    ViewBag.Title = Model.Language == "ru" ? "Кто мы" : "Who we are";

    var mainBlocks = Model.Blocks.Where(b => b.Style?.Name != "section-title").ToList();
    var sectionTitle = Model.Blocks.FirstOrDefault(b => b.Style?.Name == "section-title");
}

<section class="container">
    @foreach (var b in mainBlocks.Where(b => b.Style?.Name == "breadcrumb"))
    {
        @await Html.PartialAsync("_ContentBlock", b)
    }

    <div class="content-text-split">
        <div class="e-text">
            @foreach (var b in mainBlocks.Where(b => b.Style?.Name != "breadcrumb"))
            {
                @await Html.PartialAsync("_ContentBlock", b)
            }
        </div>
    </div>
</section>

@if (sectionTitle != null || Model.Sections.Any())
{
    <section class="container">
        @if (sectionTitle != null)
        {
            @await Html.PartialAsync("_ContentBlock", sectionTitle)
        }
    </section>
    <div class="cards m-type-2 m-type-2a">
        @foreach (var sec in Model.Sections.Take(4))
        {
            var page = sec.Pages?.FirstOrDefault(p => p.LanguageCode == Model.Language);
            var pageName = page?.Name ?? sec.Slug;
            var status = page?.Status ?? sec.Slug;
            var summary = page?.Summary ?? "";
            <a href="@Url.Action("Detail", "Case", new { slug = sec.Slug, lang = Model.Language })" class="cards__item">
                <div class="e-status" style="color:@sec.StatusColor">@status</div>
                <h2>@pageName</h2>
                @if (!string.IsNullOrEmpty(sec.FlagImage))
                {
                    <div class="e-location">
                        <span class="flag-icon"><img src="~/images/@sec.FlagImage.Replace("images/", "")" alt=""></span>
                        @summary
                    </div>
                }
            </a>
        }
    </div>
}