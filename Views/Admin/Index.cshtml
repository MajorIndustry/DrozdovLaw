}

.chip-p {
background: #f0fdf4;
color: #166534;
border-color: #bbf7d0
}

.chip-sp {
background: #fff7ed;
color: #c2410c;
border-color: #fed7aa
}

.chip-ls {
background: #f0f9ff;
color: #0369a1;
border-color: #bae6fd
}

.chip-mt {
background: #fef3c7;
color: #92400e;
border-color: #fde68a
}

.chip-as {
background: #fdf2f8;
color: #9d174d;
border-color: #fbcfe8
}

.chip-bt {
background: #f0fdf4;
color: #065f46;
border-color: #a7f3d0
}

.preview-text {
max-width: 340px;
overflow: hidden;
text-overflow: ellipsis;
white-space: nowrap;
color: #4a5568
}

.preview-meta {
font-size: 11px;
color: #a0aec0;
margin-top: 2px
}

.order-num {
color: #a0aec0;
font-size: 12px;
font-weight: 600;
text-align: center
}

.actions {
display: flex;
gap: 4px
}

.meta-bar {
background: #fff;
border-bottom: 1px solid #e2e8f0;
