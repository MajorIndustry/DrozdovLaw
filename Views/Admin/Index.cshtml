}

.case-card__flag {
margin-top: 8px;
}

.case-card__flag img {
width: 32px;
height: auto;
border-radius: 4px;
border: 1px solid #e2e8f0;
}
</style>

</head> <body> <header class="topbar"> <div class="topbar__logo">⚖️ Drozdov Law <span>Admin</span></div> <div class="topbar__right"> <div class="lang-toggle"> <a href="@Url.Action("Index", "Admin", new { section = activeSection, slug, pageName, lang = "ru" })" class="@(lang == "ru" ? "active" : "")">🇷🇺 RU</a> <a href="@Url.Action("Index", "Admin", new { section = activeSection, slug, pageName, lang = "en" })" class="@(lang == "en" ? "active" : "")">🇬🇧 EN</a> </div> <a href="/" class="topbar__site">← На сайт</a> </div> </header> <div class="workspace"> <nav class="sidebar"> <div class="sidebar__section"> <div class="sidebar__label">Разделы</div> <a href="@Url.Action("Index", "Admin", new { section = "cases", lang })" class="sidebar__link section-link @(activeSection == "cases" ? "active" : "")"> 📄 Все разделы <span>@Model.Sections.Count</span> </a> @foreach (var sec in Model.Sections) { var isActive = activeSection == "case-detail" && slug == sec.Slug; <div> <a href="@Url.Action("Index", "Admin", new { section = "case-detail", slug = sec.Slug, pageName = "case", lang })" class="sidebar__link @(isActive ? "active" : "")" style="padding-left:28px;"> @if (!sec.IsPublished) { <span>🔒</span> } @sec.Slug <span class="lang-badge @lang">@lang</span> </a> @if (isActive) { <div class="case-links"> <a href="@Url.Action("Index", "Admin", new { section = "case-detail", slug = sec.Slug, pageName = "case", lang = "ru" })" class="@(lang == "ru" ? "active" : "")">🇷🇺 RU</a> <a href="@Url.Action("Index", "Admin", new { section = "case-detail", slug = sec.Slug, pageName = "case", lang = "en" })" class="@(lang == "en" ? "active" : "")">🇬🇧 EN</a> <a href="@Url.Action("EditSection", "Admin", new { id = sec.Id, lang })">✏️ Метаданные</a> </div> } </div> } <div class="sidebar__divider"></div> <a href="@Url.Action("CreateSection", "Admin")" class="sidebar__link" style="color:#16a34a;">➕ Добавить раздел</a> </div> <div class="sidebar__divider"></div> <div class="sidebar__section"> <div class="sidebar__label">Статические страницы</div> <a href="@Url.Action("Index", "Admin", new { section = "whoweare", pageName = "whoweare", lang })" class="sidebar__link section-link @(activeSection == "whoweare" ? "active" : "")"> 👥 Кто мы <span class="lang-badge @lang">@lang</span> </a> </div> <div class="sidebar__divider"></div> <div class="sidebar__section"> <div class="sidebar__label">Система</div> <a href="@Url.Action("Languages", "Admin")" class="sidebar__link"> 🌐 Языки </a> </div> </nav> <div class="main"> @if (TempData["Success"] != null) { <div class="alert"> ✅ @TempData["Success"] <a href="#" onclick="openPreview('@pageName','@lang','@slug','@activeSection'); return false;">Открыть предпросмотр →</a> </div> }
@if (activeSection == "cases")
{

<div class="toolbar"> <div class="toolbar__left"> <div class="toolbar__title">Управление разделами</div> <span class="toolbar__count">@Model.Sections.Count разделов</span> </div> <div class="toolbar__right"> <a href="@Url.Action("CreateSection", "Admin")" class="btn btn-success">➕ Новый раздел</a> </div> </div> <div class="content-area"> <div class="cases-grid"> @foreach (var sec in Model.Sections) { var page = sec.Pages?.FirstOrDefault(p => p.LanguageCode == lang); var fallbackPage = sec.Pages?.FirstOrDefault(); var status = page?.Status ?? fallbackPage?.Status ?? sec.Slug; var title = page?.Name ?? fallbackPage?.Name ?? sec.Slug; var summary = page?.Summary ?? fallbackPage?.Summary ?? ""; var flag = sec.FlagImage; var hasFlag = !string.IsNullOrEmpty(flag); <div class="case-card @(sec.IsPublished ? "" : "unpublished")" onclick="window.location.href='@Url.Action("Index", "Admin", new { section = "case-detail", slug = sec.Slug, pageName = "case", lang })'"> <div class="case-card__header"> <div class="case-card__status"> <div class="case-card__status-dot" style="background:@sec.StatusColor"></div> <span style="color:@sec.StatusColor">@status</span> </div> <div class="case-card__title">@title</div> @if (hasFlag) { <div class="case-card__flag"> <img src="~/@flag" alt="" /> </div> } </div> <div class="case-card__body"> <div class="case-card__summary">@summary</div> </div> <div class="case-card__footer" onclick="event.stopPropagation();"> <div class="case-card__actions"> <a href="@Url.Action("Index", "Admin", new { section = "case-detail", slug = sec.Slug, pageName = "case", lang })" class="btn btn-outline btn-sm">✏️ Редактировать</a> <form method="post" action="@Url.Action("DeleteSection","Admin")" onsubmit="return confirm('Удалить раздел «@title»?')"> @Html.AntiForgeryToken() <input type="hidden" name="id" value="@sec.Id"> <button type="submit" class="btn btn-danger btn-sm">🗑️ Удалить</button> </form> </div> <div class="case-card__badge">@sec.CreatedAt.ToString("dd.MM.yy")</div> </div> </div> } <a href="@Url.Action("CreateSection", "Admin")" class="add-case-card"> <div class="icon">➕</div> <p>Добавить раздел</p> </a> </div> </div> }
@if (activeSection == "case-detail" || activeSection == "whoweare")
{
@if (isCaseDetail && Model.SelectedSection != null)
{
var sec = Model.SelectedSection;
var displayPage = sec.Pages?.FirstOrDefault(p => p.LanguageCode == lang);

<div class="meta-bar"> <div class="meta-bar__item"> <div class="meta-bar__dot" style="background:@sec.StatusColor"></div> <span>@(displayPage?.Status ?? sec.Slug)</span> </div> <span class="meta-bar__sep">|</span> <a href="@Url.Action("EditSection", "Admin", new { id = sec.Id, lang })" class="btn btn-ghost btn-sm">⚙️ Метаданные</a> <a href="@Url.RouteUrl("case-detail", new { slug = sec.Slug })?lang=@lang" target="_blank" class="btn btn-ghost btn-sm">↗️ Открыть</a> </div> } <div class="toolbar"> <div class="toolbar__left"> <div class="toolbar__title"> @if (isCaseDetail && Model.SelectedSection != null) { var page = Model.SelectedSection.Pages?.FirstOrDefault(p => p.LanguageCode == lang); @(page?.Name ?? Model.SelectedSection.Slug) } else { @(Model.SelectedPage?.Name ?? (activeSection == "whoweare" ? (lang == "ru" ? "Кто мы" : "Who we are") : pageName)) } </div> <span class="toolbar__sub">@lang.ToUpper()</span> @if (Model.Blocks.Any()) { <span class="toolbar__count">@Model.Blocks.Count блоков</span> }
@if (isCaseDetail && Model.SelectedSection != null)
{

<div class="lang-tabs"> @foreach (var pg in Model.SelectedSection.Pages.OrderBy(p => p.LanguageCode)) { <a href="@Url.Action("Index", "Admin", new { section = "case-detail", slug = Model.SelectedSection.Slug, pageName = "case", lang = pg.LanguageCode })" class="lang-tab @(lang == pg.LanguageCode ? "active" : "")"> @pg.LanguageCode.ToUpper() </a> } </div> <div style="margin-left: auto;"> <form method="post" action="@Url.Action("CopyAndTranslateBlocks","Admin")" style="display:inline"> @Html.AntiForgeryToken() <input type="hidden" name="slug" value="@Model.SelectedSection.Slug" /> <input type="hidden" name="sourceLang" value="@lang" /> <button type="submit" class="btn btn-outline btn-sm">📋 Скопировать и перевести блоки с @lang.ToUpper()</button> </form> </div> } else if (activeSection == "whoweare") { <div class="lang-tabs"> @foreach (var lng in Model.AvailableLanguagesForStatic ?? new List<Language>()) { <a href="@Url.Action("Index", "Admin", new { section = "whoweare", pageName = "whoweare", lang = lng.Code })" class="lang-tab @(lang == lng.Code ? "active" : "")"> @lng.Code.ToUpper() </a> } </div> } </div> <div class="toolbar__right"> <button class="btn btn-preview @(showPreview ? "active" : "")" onclick="openPreview('@pageName','@lang','@slug','@activeSection')"> 👁️ Предпросмотр </button> <a href="@Url.Action("CreateBlock", "Admin", new { page = pageName, lang, section = activeSection, slug })" class="btn btn-primary">➕ Блок</a> </div> </div> <div class="content-area"> <div class="table-wrap"> @if (!Model.Blocks.Any()) { <div class="empty-state"> <div class="icon">📋</div> <h3>Блоков нет</h3> <p>Добавьте первый блок кнопкой выше</p> </div> } else { <p class="drag-hint">↕️ Перетащите строки для изменения порядка — сохраняется автоматически</p> <table class="blocks-table"> <thead> <tr> <th style="width:32px"></th> <th style="width:32px">#</th> <th style="width:160px">Стиль</th> <th>Содержимое</th> <th style="width:115px">Действия</th> </tr> </thead> <tbody id="sortableBody"> @foreach (var block in Model.Blocks) { var styleName = block.Style?.Name ?? ""; var chipCls = styleName switch { "h1" or "h2" or "h3" or "h4" or "h5" or "section-title" => "chip-h", "p" or "p-large" or "blockquote" or "small" => "chip-p", "e-id" or "e-dots" or "e-details__type" or "e-details__loc" or "e-details__def" => "chip-sp", "ul" or "ol" => "chip-ls", "person" or "note-title" or "note-text" => "chip-as", "decision-title" or "decision-text" or "case-link" or "docs-title" or "doc-item" or "tags-title" or "tag" => "chip-bt", _ => "chip-mt" }; <tr draggable="true" data-id="@block.Id"> <td><span class="drag-handle">↕️</span></td> <td class="order-num">@block.Order</td> <td><span class="style-chip @chipCls">@styleName</span></td> <td> <div class="preview-text" title="@block.Content"> @(block.Content?.Length > 80 ? block.Content[..80] + "…" : block.Content) </div> <div class="preview-meta">@block.UpdatedAt.ToString("dd.MM.yy HH:mm")</div> </td> <td> <div class="actions"> <a href="@Url.Action("EditBlock", "Admin", new { id = block.Id, returnPage = pageName, lang, section = activeSection, slug })" class="btn btn-outline btn-sm btn-icon">✏️</a> <form method="post" action="@Url.Action("DeleteBlock","Admin")" onsubmit="return confirm('Удалить блок?')"> @Html.AntiForgeryToken() <input type="hidden" name="id" value="@block.Id"> <input type="hidden" name="returnPage" value="@pageName"> <input type="hidden" name="lang" value="@lang"> <input type="hidden" name="section" value="@activeSection"> <input type="hidden" name="slug" value="@slug"> <button type="submit" class="btn btn-danger btn-sm btn-icon">🗑️</button> </form> </div> </td> </tr> } </tbody> </table> } </div> <div class="preview-panel @(showPreview ? "open" : "")" id="previewPanel"> <div class="preview-panel__head"> <div> <h3>Предпросмотр</h3> <div class="meta">@pageName · @lang.ToUpper()</div> </div> <button class="preview-close" onclick="closePreview()">×</button> </div> <div class="preview-frame-wrap"> <iframe id="previewFrame" src="@(showPreview? previewUrl:"")" data-src="@previewUrl"></iframe> </div> <div class="preview-foot"> <small>Масштаб 62.5%</small> <a href="@previewUrl" target="_blank">↗️ Открыть в новой вкладке</a> </div> </div> </div> } </div> </div> <script> const tbody = document.getElementById('sortableBody'); if (tbody) { let dragged = null; tbody.querySelectorAll('tr[draggable]').forEach(row => { row.addEventListener('dragstart', () => { dragged = row; setTimeout(() => row.classList.add('dragging'), 0); }); row.addEventListener('dragend', () => { row.classList.remove('dragging'); dragged = null; saveOrder(); }); row.addEventListener('dragover', e => { e.preventDefault(); if (!dragged || dragged === row) return; const rect = row.getBoundingClientRect(); if (e.clientY < rect.top + rect.height / 2) tbody.insertBefore(dragged, row); else tbody.insertBefore(dragged, row.nextSibling); }); }); } async function saveOrder() { const rows = document.querySelectorAll('#sortableBody tr[data-id]'); const ids = Array.from(rows).map(r => parseInt(r.dataset.id)); await fetch('@Url.Action("ReorderBlocks", "Admin")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ page: '@pageName', lang: '@lang', slug: '@slug', section: '@activeSection', ids }) }); rows.forEach((r, i) => { const cell = r.querySelector('.order-num'); if (cell) cell.textContent = i + 1; }); if (document.getElementById('previewPanel').classList.contains('open')) { reloadPreview(); } } const panel = document.getElementById('previewPanel'); const frame = document.getElementById('previewFrame'); function openPreview(pageName, lang, slug, section) { const url = '@Url.Action("Preview", "Admin")' + '?pageName=' + encodeURIComponent(pageName) + '&lang=' + encodeURIComponent(lang) + '&slug=' + encodeURIComponent(slug || '') + '&section=' + encodeURIComponent(section); frame.src = url; panel.classList.add('open'); document.querySelector('.btn-preview')?.classList.add('active'); } function closePreview() { panel.classList.remove('open'); frame.src = ''; document.querySelector('.btn-preview')?.classList.remove('active'); } function togglePreview() { panel.classList.contains('open') ? closePreview() : openPreview('@pageName','@lang','@slug','@activeSection'); } function reloadPreview() { if (frame && frame.src) { frame.src = frame.src; } } @if (showPreview) { <text>window.addEventListener('load', () => openPreview('@pageName','@lang','@slug','@activeSection'));</text> } </script></body> </html> ```
