.case-card.unpublished::after {
content: 'Скрыт';
position: absolute;
top: 10px;
right: 10px;
background: #fef3c7;
color: #92400e;
font-size: 10px;
font-weight: 700;
padding: 2px 8px;
border-radius: 10px;
