@model DrozdovLaw.Models.ViewModels.AdminIndexViewModel
@{
Layout = null;
var lang = Model.ActiveLang;
var activeSection = Model.ActiveSection;
var pageName = Model.SelectedPage?.SystemName ?? (activeSection == "whoweare" ? "whoweare" : "case");
var slug = Model.SelectedSection?.Slug ?? "";
var previewUrl = !string.IsNullOrEmpty(pageName) ? Url.Action("Preview", "Admin", new { pageName, lang, slug, section = activeSection }) : "";
var showPreview = TempData["ShowPreview"] != null;
bool isCaseDetail = activeSection == "case-detail" && Model.SelectedSection != null;
}

<!DOCTYPE html><html lang="ru"> <head> <meta charset="UTF-8"> <title>Админ — Drozdov Law</title> <meta name="viewport" content="width=device-width, initial-scale=1"> <style> *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
body {
