@model DrozdovLaw.Models.Language
@{
    Layout = null;
    var supportedLanguages = ViewBag.SupportedLanguages as List<DrozdovLaw.Interfaces.LanguageInfo> ?? new();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Добавления языков — Drozdov Law Admin</title>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
            background: #eef1f6;
            min-height: 100vh
        }

        .ph {
            background: #1a1a2e;
            color: #fff;
            padding: 0 32px;
            height: 52px;
            display: flex;
            align-items: center;
            gap: 16px
        }

            .ph a {
                color: #7eb8d4;
                text-decoration: none;
                font-size: 13px
            }

            .ph h1 {
                font-size: 15px;
                font-weight: 700;
                color: #fff;
                margin-left: 8px
            }

        .pb {
            max-width: 760px;
            margin: 32px auto;
            padding: 0 20px
        }

        .card {
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
            box-shadow: 0 1px 3px rgba(0,0,0,.05);
            margin-bottom: 20px
        }

        .ch {
            padding: 20px 24px;
            border-bottom: 1px solid #e2e8f0
        }

            .ch h2 {
                font-size: 17px;
                font-weight: 700;
                color: #1a202c
            }

            .ch p {
                font-size: 13px;
                color: #718096;
                margin-top: 2px
            }

        .cb {
            padding: 24px
        }

        .fg {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-bottom: 14px
        }

            .fg label {
                font-size: 11px;
                font-weight: 700;
                color: #4a5568;
                text-transform: uppercase;
                letter-spacing: .4px
            }

            .fg input {
                padding: 9px 12px;
                border: 1px solid #e2e8f0;
                border-radius: 7px;
                font-size: 14px;
                color: #1a202c;
                font-family: inherit;
                transition: .12s;
                background: #fff;
                width: 100%
            }

                .fg input:focus {
                    outline: none;
                    border-color: #1a6fa8;
                    box-shadow: 0 0 0 3px rgba(26,111,168,.1)
                }

                .fg input[readonly] {
                    background: #f7fafc;
                    color: #718096
                }

        .hint {
            font-size: 11px;
            color: #a0aec0;
            margin-top: 3px
        }

        .cf {
            padding: 16px 24px;
            border-top: 1px solid #f0f4f8;
            background: #fafbfc;
            display: flex;
            align-items: center;
            justify-content: space-between
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 18px;
            border-radius: 7px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: .12s
        }

        .btn-primary {
            background: #1a6fa8;
            color: #fff
        }

            .btn-primary:hover {
                background: #155d8e
            }

        .btn-outline {
            background: #fff;
            color: #4a5568;
            border: 1px solid #e2e8f0
        }

            .btn-outline:hover {
                border-color: #1a6fa8;
                color: #1a6fa8
            }
    </style>
</head>
<body>
    <header class="ph">
        <a href="@Url.Action("Languages")">← Назад</a>
        <span>|</span>
        <h1>Добавить язык</h1>
    </header>
    <div class="pb">
        <div class="card">
            <div class="ch"><h2>Выберите язык</h2></div>
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="cb">
                    <div class="fg">
                        <label>Язык</label>
                        <select name="Code" id="languageSelect" required>
                            <option value="">-- выберите --</option>
                            @foreach (var lang in supportedLanguages)
                            {
                                <option value="@lang.Code" data-name="@lang.Name">@lang.Name (@lang.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="fg">
                        <label>Название</label>
                        <input name="Name" id="languageName" readonly required />
                    </div>
                </div>
                <div class="cf">
                    <button type="submit" class="btn btn-primary">Добавить</button>
                    <a href="@Url.Action("Languages")" class="btn btn-outline">Отмена</a>
                </div>
            </form>
        </div>
    </div>
    <script>
        document.getElementById('languageSelect').addEventListener('change', function() {
            var selected = this.options[this.selectedIndex];
            document.getElementById('languageName').value = selected.dataset.name || '';
        });
    </script>
</body>
</html>