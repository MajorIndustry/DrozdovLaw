@model DrozdovLaw.Models.ViewModels.CreateSectionViewModel
@{
    Layout = null;
    var allLanguages = ViewBag.Languages as List<DrozdovLaw.Models.Language> ?? new List<DrozdovLaw.Models.Language>();
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Новый раздел — Drozdov Law Admin</title>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
            background: #eef1f6;
            min-height: 100vh
        }

        .page-header {
            background: #1a1a2e;
            color: #fff;
            padding: 0 32px;
            height: 52px;
            display: flex;
            align-items: center;
            gap: 16px
        }

            .page-header a {
                color: #7eb8d4;
                text-decoration: none;
                font-size: 13px
            }

            .page-header h1 {
                font-size: 15px;
                font-weight: 700;
                color: #fff;
                margin-left: 8px
            }

        .page-body {
            max-width: 760px;
            margin: 32px auto;
            padding: 0 20px
        }

        .card {
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
            box-shadow: 0 1px 3px rgba(0,0,0,.05)
        }

        .card__head {
            padding: 20px 24px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between
        }

            .card__head h2 {
                font-size: 17px;
                font-weight: 700;
                color: #1a202c
            }

            .card__head p {
                font-size: 13px;
                color: #718096;
                margin-top: 2px
            }

        .card__body {
            padding: 24px
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px
        }

        .form-full {
            grid-column: 1/-1
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 5px
        }

            .form-group label {
                font-size: 12px;
                font-weight: 700;
                color: #4a5568;
                text-transform: uppercase;
                letter-spacing: .4px
            }

            .form-group input, .form-group textarea, .form-group select {
                padding: 9px 12px;
                border: 1px solid #e2e8f0;
                border-radius: 7px;
                font-size: 14px;
                color: #1a202c;
                font-family: inherit;
                transition: .12s;
                background: #fff
            }

                .form-group input:focus, .form-group textarea:focus {
                    outline: none;
                    border-color: #1a6fa8;
                    box-shadow: 0 0 0 3px rgba(26,111,168,.1)
                }

            .form-group textarea {
                resize: vertical;
                min-height: 72px;
                line-height: 1.5
            }

        .form-hint {
            font-size: 11px;
            color: #a0aec0;
            margin-top: 3px
        }

        .form-error {
            font-size: 12px;
            color: #e53e3e;
            margin-top: 3px
        }

        .section-sep {
            font-size: 12px;
            font-weight: 700;
            color: #a0aec0;
            text-transform: uppercase;
            letter-spacing: .8px;
            margin: 20px 0 14px;
            padding-bottom: 6px;
            border-bottom: 1px solid #f0f4f8
        }

        .color-row {
            display: flex;
            align-items: center;
            gap: 10px
        }

            .color-row input[type=color] {
                width: 44px;
                height: 36px;
                padding: 2px;
                border: 1px solid #e2e8f0;
                border-radius: 7px;
                cursor: pointer
            }

        .card__footer {
            padding: 16px 24px;
            border-top: 1px solid #f0f4f8;
            background: #fafbfc;
            display: flex;
            align-items: center;
            justify-content: space-between
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 18px;
            border-radius: 7px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: .12s
        }

        .btn-success {
            background: #16a34a;
            color: #fff
        }

            .btn-success:hover {
                background: #15803d
            }

        .btn-outline {
            background: #fff;
            color: #4a5568;
            border: 1px solid #e2e8f0
        }

            .btn-outline:hover {
                border-color: #1a6fa8;
                color: #1a6fa8
            }

        .info-box {
            background: #f0f9ff;
            border: 1px solid #bae6fd;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 13px;
            color: #0c4a6e;
            margin-bottom: 20px;
            line-height: 1.5
        }

            .info-box strong {
                font-weight: 700
            }
    </style>
</head>
<body>
    <header class="page-header">
        <a href="@Url.Action("Index", "Admin")">← Назад в админку</a>
        <span>|</span>
        <h1>Создать новый раздел</h1>
    </header>

    <div class="page-body">
        <div class="info-box">
            <strong>Как это работает:</strong> заполните данные на ОДНОМ языке (например, русском). После сохранения все остальные языки будут автоматически переведены с помощью Google Translate. Вы сможете отредактировать любой перевод позже.
        </div>

        <div class="card">
            <div class="card__head">
                <div>
                    <h2>Основная информация</h2>
                    <p>Метаданные раздела — используются для карточек и навигации</p>
                </div>
            </div>
            <form method="post" action="@Url.Action("CreateSection","Admin")">
                @Html.AntiForgeryToken()
                <div class="card__body">

                    <div class="section-sep">URL и идентификатор</div>
                    <div class="form-group form-full" style="margin-bottom:16px">
                        <label>Slug (URL-идентификатор) <span style="color:#e53e3e">*</span></label>
                        <input type="text" name="Slug" value="@Model.Slug" placeholder="kk-vs-switzerland" required
                               pattern="[a-z0-9\-]+" title="Только строчные латинские буквы, цифры и дефис">
                        <div class="form-hint">Пример: <code>kk-vs-switzerland</code></div>
                        @Html.ValidationMessage("Slug", new { @class = "form-error" })
                    </div>

                    <div class="section-sep">Данные для перевода</div>
                    <div class="form-group form-full" style="margin-bottom:16px">
                        <label>Язык, на котором вы заполняете</label>
                        <select name="BaseLanguageCode" asp-for="BaseLanguageCode">
                            @foreach (var lang in allLanguages)
                            {
                                <option value="@lang.Code">@lang.Name (@lang.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group form-full" style="margin-bottom:16px">
                        <label>Название <span style="color:#e53e3e">*</span></label>
                        <input type="text" name="BaseTitle" value="@Model.BaseTitle" placeholder="К.К. против Швейцарии" required>
                    </div>
                    <div class="form-group form-full" style="margin-bottom:16px">
                        <label>Статус</label>
                        <input type="text" name="BaseStatus" value="@Model.BaseStatus" placeholder="Завершено успешно">
                    </div>
                    <div class="form-group form-full" style="margin-bottom:16px">
                        <label>Краткое описание</label>
                        <textarea name="BaseSummary">@Model.BaseSummary</textarea>
                    </div>

                    <div class="section-sep">Общие данные</div>
                    <div class="form-grid" style="margin-bottom:16px">
                        <div class="form-group form-full">
                            <label>Цвет статуса</label>
                            <div class="color-row">
                                <input type="color" name="StatusColor" id="statusColor" value="@Model.StatusColor"
                                       oninput="document.getElementById('statusColorHex').value=this.value">
                                <input type="text" id="statusColorHex" value="@Model.StatusColor" placeholder="#B4D4EB"
                                       oninput="document.getElementById('statusColor').value=this.value">
                            </div>
                        </div>
                    </div>

                    <div class="form-group form-full" style="margin-bottom:16px">
                        <label>Путь к флагу</label>
                        <input type="text" name="FlagImage" value="@Model.FlagImage" placeholder="images/flag-sw.png">
                    </div>

                </div>

                <div class="card__footer">
                    <a href="@Url.Action("Index", "Admin")" class="btn btn-outline">Отмена</a>
                    <button type="submit" class="btn btn-success">✓ Создать раздел и открыть редактор</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>