@model DrozdovLaw.Models.CreateCaseViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Новый кейс — Drozdov Law Admin</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#eef1f6;min-height:100vh}
.page-header{background:#1a1a2e;color:#fff;padding:0 32px;height:52px;display:flex;align-items:center;gap:16px}
.page-header a{color:#7eb8d4;text-decoration:none;font-size:13px}
.page-header h1{font-size:15px;font-weight:700;color:#fff;margin-left:8px}
.page-body{max-width:760px;margin:32px auto;padding:0 20px}
.card{background:#fff;border-radius:12px;border:1px solid #e2e8f0;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.card__head{padding:20px 24px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between}
.card__head h2{font-size:17px;font-weight:700;color:#1a202c}
.card__head p{font-size:13px;color:#718096;margin-top:2px}
.card__body{padding:24px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-full{grid-column:1/-1}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-group label{font-size:12px;font-weight:700;color:#4a5568;text-transform:uppercase;letter-spacing:.4px}
.form-group input,.form-group textarea,.form-group select{padding:9px 12px;border:1px solid #e2e8f0;border-radius:7px;font-size:14px;color:#1a202c;font-family:inherit;transition:.12s;background:#fff}
.form-group input:focus,.form-group textarea:focus{outline:none;border-color:#1a6fa8;box-shadow:0 0 0 3px rgba(26,111,168,.1)}
.form-group textarea{resize:vertical;min-height:72px;line-height:1.5}
.form-hint{font-size:11px;color:#a0aec0;margin-top:3px}
.form-error{font-size:12px;color:#e53e3e;margin-top:3px}
.lang-pair{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.lang-pair-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;padding:3px 8px;border-radius:4px;margin-bottom:4px;display:inline-block}
.lang-pair-label.ru{background:#fff5f5;color:#e53e3e}
.lang-pair-label.en{background:#ebf8ff;color:#2b6cb0}
.section-sep{font-size:12px;font-weight:700;color:#a0aec0;text-transform:uppercase;letter-spacing:.8px;margin:20px 0 14px;padding-bottom:6px;border-bottom:1px solid #f0f4f8}
.color-row{display:flex;align-items:center;gap:10px}
.color-row input[type=color]{width:44px;height:36px;padding:2px;border:1px solid #e2e8f0;border-radius:7px;cursor:pointer}
.color-presets{display:flex;gap:6px;flex-wrap:wrap}
.color-preset{width:24px;height:24px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:.12s}
.color-preset:hover{transform:scale(1.15);border-color:#fff;box-shadow:0 0 0 2px #1a6fa8}
.card__footer{padding:16px 24px;border-top:1px solid #f0f4f8;background:#fafbfc;display:flex;align-items:center;justify-content:space-between}
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:7px;font-size:14px;font-weight:600;text-decoration:none;cursor:pointer;border:none;transition:.12s}
.btn-success{background:#16a34a;color:#fff}.btn-success:hover{background:#15803d}
.btn-outline{background:#fff;color:#4a5568;border:1px solid #e2e8f0}.btn-outline:hover{border-color:#1a6fa8;color:#1a6fa8}
.info-box{background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:12px 16px;font-size:13px;color:#0c4a6e;margin-bottom:20px;line-height:1.5}
.info-box strong{font-weight:700}
</style>
</head>
<body>
<header class="page-header">
    <a href="@Url.Action("Index","Admin")">&#8592; Назад в админку</a>
    <span style="color:#374151">|</span>
    <h1>Создать новый кейс</h1>
</header>

<div class="page-body">
    <div class="info-box">
        <strong>Как это работает:</strong> после создания кейса автоматически генерируются <strong>RU и EN версии</strong>
        со структурой как у кейса 1 (хлебные крошки, заголовок, детали, основной текст, адвокаты, решение, документы, теги).
        Затем каждую версию можно редактировать блочно в админ-панели.
    </div>

    <div class="card">
        <div class="card__head">
            <div>
                <h2>Основная информация</h2>
                <p>Метаданные кейса — используются для карточек и навигации</p>
            </div>
        </div>
        <form method="post" action="@Url.Action("CreateCase","Admin")">
            @Html.AntiForgeryToken()
            <div class="card__body">

                <div class="section-sep">URL и идентификатор</div>
                <div class="form-group form-full" style="margin-bottom:16px">
                    <label>Slug (URL-идентификатор) <span style="color:#e53e3e">*</span></label>
                    <input type="text" name="Slug" value="@Model.Slug" placeholder="kk-vs-switzerland" required
                           pattern="[a-z0-9\-]+" title="Только строчные латинские буквы, цифры и дефис">
                    <div class="form-hint">Только строчные латинские буквы, цифры и дефис. Пример: <code>kk-vs-switzerland</code></div>
                    @Html.ValidationMessage("Slug", new { @class = "form-error" })
                </div>

                <div class="section-sep">Заголовки</div>
                <div class="lang-pair" style="margin-bottom:16px">
                    <div class="form-group">
                        <span class="lang-pair-label ru">&#127479;&#127482; Русский</span>
                        <label>Название кейса RU <span style="color:#e53e3e">*</span></label>
                        <input type="text" name="TitleRu" value="@Model.TitleRu" placeholder="К.К. против Швейцарии" required>
                        @Html.ValidationMessage("TitleRu", new { @class = "form-error" })
                    </div>
                    <div class="form-group">
                        <span class="lang-pair-label en">&#127468;&#127463; English</span>
                        <label>Название кейса EN <span style="color:#e53e3e">*</span></label>
                        <input type="text" name="TitleEn" value="@Model.TitleEn" placeholder="K.K. v. Switzerland" required>
                        @Html.ValidationMessage("TitleEn", new { @class = "form-error" })
                    </div>
                </div>

                <div class="section-sep">Статус</div>
                <div class="form-grid" style="margin-bottom:16px">
                    <div class="form-group">
                        <label>Статус RU</label>
                        <input type="text" name="StatusRu" value="@Model.StatusRu" placeholder="Завершено успешно">
                    </div>
                    <div class="form-group">
                        <label>Статус EN</label>
                        <input type="text" name="StatusEn" value="@Model.StatusEn" placeholder="Successfully completed">
                    </div>
                    <div class="form-group form-full">
                        <label>Цвет статуса</label>
                        <div class="color-row">
                            <input type="color" name="StatusColor" id="statusColor" value="@Model.StatusColor"
                                   oninput="document.getElementById('statusColorHex').value=this.value">
                            <input type="text" id="statusColorHex" value="@Model.StatusColor" placeholder="#B4D4EB"
                                   oninput="document.getElementById('statusColor').value=this.value;this.previousElementSibling.previousElementSibling.value=this.value"
                                   style="width:120px">
                            <div class="color-presets">
                                <div class="color-preset" style="background:#B4D4EB" onclick="setColor('#B4D4EB')" title="#B4D4EB"></div>
                                <div class="color-preset" style="background:#EA7C3E" onclick="setColor('#EA7C3E')" title="#EA7C3E"></div>
                                <div class="color-preset" style="background:#B8B399" onclick="setColor('#B8B399')" title="#B8B399"></div>
                                <div class="color-preset" style="background:#86D6B9" onclick="setColor('#86D6B9')" title="#86D6B9"></div>
                                <div class="color-preset" style="background:#D5A968" onclick="setColor('#D5A968')" title="#D5A968"></div>
                                <div class="color-preset" style="background:#1E6F89" onclick="setColor('#1E6F89')" title="#1E6F89"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-sep">Локация</div>
                <div class="lang-pair" style="margin-bottom:6px">
                    <div class="form-group">
                        <label>Локация RU</label>
                        <input type="text" name="LocationRu" value="@Model.LocationRu" placeholder="Швейцария / Комитет ООН">
                    </div>
                    <div class="form-group">
                        <label>Локация EN</label>
                        <input type="text" name="LocationEn" value="@Model.LocationEn" placeholder="Switzerland / UN Committee">
                    </div>
                </div>
                <div class="form-group form-full" style="margin-bottom:16px">
                    <label>Путь к флагу</label>
                    <input type="text" name="FlagImage" value="@Model.FlagImage" placeholder="images/flag-sw.png">
                    <div class="form-hint">Относительный путь от wwwroot. Примеры: images/flag-sw.png, images/flag-de.png</div>
                </div>

                <div class="section-sep">Краткое описание (для карточек)</div>
                <div class="lang-pair">
                    <div class="form-group">
                        <label>Описание RU</label>
                        <textarea name="SummaryRu" placeholder="Краткое описание дела для отображения в карточке...">@Model.SummaryRu</textarea>
                    </div>
                    <div class="form-group">
                        <label>Описание EN</label>
                        <textarea name="SummaryEn" placeholder="Brief case description for card display...">@Model.SummaryEn</textarea>
                    </div>
                </div>
            </div>

            <div class="card__footer">
                <a href="@Url.Action("Index","Admin")" class="btn btn-outline">Отмена</a>
                <button type="submit" class="btn btn-success">&#10003; Создать кейс и открыть редактор</button>
            </div>
        </form>
    </div>
</div>

<script>
function setColor(hex) {
    document.getElementById('statusColor').value = hex;
    document.getElementById('statusColorHex').value = hex;
}
// Авто-slug из русского заголовка
document.querySelector('input[name=TitleRu]').addEventListener('input', function() {
    const slug = document.querySelector('input[name=Slug]');
    if (slug.dataset.manual) return;
    // Простая транслитерация
    const map = {'а':'a','б':'b','в':'v','г':'g','д':'d','е':'e','ё':'yo','ж':'zh','з':'z','и':'i','й':'j','к':'k','л':'l','м':'m','н':'n','о':'o','п':'p','р':'r','с':'s','т':'t','у':'u','ф':'f','х':'h','ц':'ts','ч':'ch','ш':'sh','щ':'shch','ъ':'','ы':'y','ь':'','э':'e','ю':'yu','я':'ya',' ':'-','.':"",',':""};
    let res = this.value.toLowerCase().split('').map(c=>map[c]!==undefined?map[c]:c).join('').replace(/[^a-z0-9-]/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'').slice(0,60);
    slug.value = res;
});
document.querySelector('input[name=Slug]').addEventListener('input', function() { this.dataset.manual = '1'; });
</script>
</body>
</html>
